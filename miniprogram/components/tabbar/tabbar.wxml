<view class="tabbar-wrap">
  <view class="tabbar">
    <view
      wx:for="{{tabs}}" wx:key="key"
      class="tab {{item.key === active ? 'on' : ''}}"
      data-tab="{{item}}" bindtap="onTap"
    >
      <text class="tab-icon">{{item.icon}}</text>
      <text class="tab-label">{{item.label}}</text>
    </view>
  </view>
</view>
