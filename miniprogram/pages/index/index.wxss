.page { min-height: 100vh; padding-bottom: 40rpx; }

/* 搜索胶囊（HIG 风：填充灰底、无边框） */
.search-wrap { padding: 12rpx 24rpx 8rpx; }
.search-pill {
  display: flex;
  align-items: center;
  height: 80rpx;
  padding: 0 24rpx;
  background: var(--c-bg-chip);
  border-radius: 999rpx;
  gap: 12rpx;
}
.s-icon { font-size: 28rpx; opacity: .6; }
.s-input {
  flex: 1;
  height: 80rpx;
  font-size: 28rpx;
  color: var(--c-text);
}
.s-picker {
  font-size: 26rpx;
  color: var(--c-text-2);
  padding-left: 12rpx;
  border-left: 1rpx solid var(--c-separator);
}

/* 分段排序（HIG Segmented Control 风） */
.segment {
  display: flex;
  margin: 20rpx 24rpx 8rpx;
  padding: 6rpx;
  background: var(--c-bg-chip);
  border-radius: 999rpx;
}
.seg-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: var(--c-text-2);
  border-radius: 999rpx;
  transition: all .25s ease;
}
.seg-item.on {
  background: var(--c-bg-elev);
  color: var(--c-text);
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,.08);
}

.empty { text-align: center; color: var(--c-text-3); padding: 160rpx 0; }

/* 列表卡片 */
.list { padding: 16rpx 0; }
.court-card {
  display: flex;
  gap: 20rpx;
  padding: 20rpx;
  margin: 16rpx 24rpx;
  background: var(--c-bg-elev);
  border-radius: 28rpx;
  box-shadow: var(--c-shadow);
  transition: transform .2s ease;
}
.card-hover { transform: scale(0.98); }

.thumb-wrap { flex-shrink: 0; }
.thumb {
  width: 200rpx;
  height: 200rpx;
  border-radius: 22rpx;
  background: var(--c-bg-chip);
}
.thumb-placeholder {
  display: flex; align-items: center; justify-content: center;
  font-size: 72rpx; color: var(--c-text-3);
}

.info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}
.court-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--c-text);
  letter-spacing: -0.2rpx;
}
.distance {
  flex-shrink: 0;
  font-size: 24rpx;
  color: var(--c-blue);
  font-weight: 500;
  padding-left: 16rpx;
}
.meta { font-size: 26rpx; }
.sm { font-size: 22rpx; }

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 4rpx;
}
.tag-type {
  background: transparent;
  border: 1rpx solid;
  font-weight: 500;
}
.tag-fac {
  padding: 4rpx 12rpx;
}

.foot { margin-top: 4rpx; }
.price-num {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--c-orange);
  letter-spacing: -0.3rpx;
}
