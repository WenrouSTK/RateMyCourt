/* 图集 */
.gallery { background: #000; }
.gallery-scroll { white-space: nowrap; height: 400rpx; }
.gallery-img {
  display: inline-block;
  width: 560rpx;
  height: 400rpx;
  margin-right: 6rpx;
  background: #222;
}
.image-tabs {
  background: #fff;
  padding: 16rpx 20rpx;
  border-bottom: 1rpx solid #f0f0f3;
}
.img-tab {
  display: inline-block;
  padding: 6rpx 20rpx;
  margin-right: 12rpx;
  font-size: 24rpx;
  color: #666;
  border-radius: 20rpx;
  background: #f0f0f3;
}
.img-tab.on {
  color: #fff;
  background: #0d6efd;
}

/* 头部 */
.header {
  background: #fff;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}
.name { font-size: 40rpx; font-weight: 700; margin-bottom: 10rpx; }
.small { font-size: 22rpx; }
.stars.big { font-size: 36rpx; font-weight: 700; color: #fa8c16; }

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 20rpx;
}
.tag {
  display: inline-block;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  background: #f5f5f7;
  color: #666;
}
.tag-type { background: #fff; border: 1rpx solid; font-weight: 500; }
.tag-fac { background: #f5f5f7; }

.actions { margin-top: 30rpx; gap: 20rpx; flex-wrap: wrap; }
.action {
  padding: 14rpx 30rpx;
  border: 1rpx solid #0d6efd;
  color: #0d6efd;
  border-radius: 30rpx;
  font-size: 26rpx;
  margin-right: 16rpx;
}

.section-title { font-size: 30rpx; font-weight: 600; margin-bottom: 20rpx; }

/* 分项评分 */
.dims { display: flex; justify-content: space-around; }
.dim { text-align: center; flex: 1; }
.dim-name { font-size: 24rpx; color: #666; margin-bottom: 8rpx; }
.dim-score { font-size: 36rpx; font-weight: 700; color: #fa8c16; }

/* 规格表 */
.spec-table { border-top: 1rpx solid #f0f0f3; }
.spec-row {
  display: flex;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f0f0f3;
  font-size: 28rpx;
}
.spec-row:last-child { border-bottom: none; }
.spec-type { flex: 1; }
.spec-count { color: #666; margin: 0 20rpx; }
.spec-cond {
  font-size: 22rpx;
  padding: 2rpx 12rpx;
  border-radius: 12rpx;
  background: #f0f0f3;
  color: #666;
}
.spec-cond.new { background: #d4edda; color: #155724; }
.spec-cond.old { background: #f8d7da; color: #721c24; }

/* 价格表 */
.price-table { border-top: 1rpx solid #f0f0f3; }
.price-row {
  display: flex;
  justify-content: space-between;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f0f0f3;
  font-size: 28rpx;
}
.price-row:last-child { border-bottom: none; }
.price-val { color: #fa541c; font-weight: 700; font-size: 30rpx; }

/* 攻略 */
.tip-line {
  display: flex;
  padding: 16rpx 0;
  line-height: 1.6;
  font-size: 28rpx;
}
.tip-icon { font-size: 36rpx; margin-right: 16rpx; flex-shrink: 0; }
.tip-text { flex: 1; color: #333; }

/* 热门标签 */
.hot-tags { display: flex; flex-wrap: wrap; gap: 12rpx; }
.hot-tag {
  padding: 8rpx 20rpx;
  background: #e7f1ff;
  color: #0d6efd;
  border-radius: 24rpx;
  font-size: 24rpx;
}

/* 评论 */
.review {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f3;
}
.review:last-child { border-bottom: none; }
.avatar { width: 60rpx; height: 60rpx; border-radius: 50%; margin-right: 16rpx; background: #eee; }
.nickname { font-size: 28rpx; color: #333; }
.r-tags { margin-top: 12rpx; display: flex; flex-wrap: wrap; gap: 8rpx; }
.r-tag {
  font-size: 22rpx;
  color: #0d6efd;
  padding: 2rpx 10rpx;
  background: #e7f1ff;
  border-radius: 12rpx;
}
.content { margin: 14rpx 0; font-size: 28rpx; line-height: 1.6; color: #333; }
.imgs { display: flex; gap: 10rpx; margin-bottom: 10rpx; flex-wrap: wrap; }
.review-img { width: 200rpx; height: 200rpx; border-radius: 8rpx; background: #eee; }
.empty { text-align: center; color: #999; padding: 40rpx 0; }

/* 底部栏 */
.footer-bar {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  padding: 16rpx 30rpx calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #eee;
}

/* 纠错弹窗 */
.mask {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,.5);
  z-index: 99;
  display: flex;
  align-items: flex-end;
}
.modal {
  width: 100%;
  background: #fff;
  border-top-left-radius: 24rpx;
  border-top-right-radius: 24rpx;
  padding: 30rpx 30rpx calc(30rpx + env(safe-area-inset-bottom));
}
.modal-title { font-size: 32rpx; font-weight: 700; }
.modal-sub { margin-top: 8rpx; }
.c-fields { margin: 24rpx 0; display: flex; flex-wrap: wrap; gap: 12rpx; }
.c-field {
  padding: 10rpx 24rpx;
  border: 1rpx solid #d1d1d6;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
}
.c-field.on { background: #0d6efd; color: #fff; border-color: #0d6efd; }
.c-input {
  width: 100%;
  min-height: 160rpx;
  padding: 20rpx;
  background: #f5f5f7;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}
.btn-ghost {
  padding: 22rpx 40rpx;
  border: 1rpx solid #d1d1d6;
  border-radius: 40rpx;
  color: #666;
  font-size: 30rpx;
}
