/* ===================================
 * 深网地图 · 场馆详情页  (Apple HIG 深色)
 * =================================== */

.small { font-size: 22rpx; }

/* --- 顶部图集 --- */
.gallery { background: #000; }
.gallery-scroll { white-space: nowrap; height: 420rpx; }
.gallery-img {
  display: inline-block;
  width: 100vw;
  height: 420rpx;
  background: var(--c-bg-elev);
}
.image-tabs {
  display: flex;
  gap: 12rpx;
  padding: 16rpx 24rpx;
  background: var(--c-bg-elev);
  border-bottom: 1rpx solid var(--c-separator);
}
.img-tab {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 22rpx;
  font-size: 24rpx;
  color: var(--c-text-2);
  background: var(--c-bg-chip);
  border-radius: 20rpx;
}
.img-tab.on {
  color: #fff;
  background: var(--c-blue);
}

/* --- 头部 --- */
.header {
  padding: 28rpx 28rpx 24rpx;
}
.name {
  font-size: 42rpx;
  font-weight: 700;
  color: var(--c-text);
  letter-spacing: -0.4rpx;
}
.header .muted {
  font-size: 24rpx;
  color: var(--c-text-2);
  margin-top: 6rpx;
}
.stars.big {
  font-size: 38rpx;
  font-weight: 700;
  color: var(--c-orange);
}

/* --- 标签行 --- */
.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 18rpx;
}
/* .tag 全局已定义，这里只补 type / fac 的特殊色 */
.tag-type {
  background: transparent;
  border: 1rpx solid;
  font-weight: 500;
}
.tag-fac {
  background: var(--c-bg-chip);
  color: var(--c-text-2);
}

/* --- 操作条 --- */
.actions { margin-top: 28rpx; gap: 16rpx; flex-wrap: wrap; }
.action {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 28rpx;
  border: 1rpx solid var(--c-blue);
  border-radius: 999rpx;
  font-size: 26rpx;
  color: var(--c-blue);
  background: transparent;
}

/* --- 分项评分 --- */
.dims {
  display: flex;
  justify-content: space-around;
  padding: 8rpx 0 4rpx;
}
.dim { text-align: center; flex: 1; }
.dim-name { font-size: 22rpx; color: var(--c-text-2); margin-bottom: 8rpx; }
.dim-score { font-size: 36rpx; font-weight: 700; color: var(--c-orange); }

/* --- 规格表 --- */
.spec-total {
  font-size: 24rpx;
  color: var(--c-text-2);
  margin-bottom: 12rpx;
}
.spec-total text { color: var(--c-text); font-weight: 600; }
.spec-table { border-top: 1rpx solid var(--c-separator); }
.spec-row {
  display: flex;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid var(--c-separator);
  font-size: 28rpx;
}
.spec-row:last-child { border-bottom: none; }
.spec-type { flex: 1; color: var(--c-text); }
.spec-count { color: var(--c-text-2); margin: 0 20rpx; }
.spec-cond {
  font-size: 22rpx;
  padding: 2rpx 14rpx;
  border-radius: 12rpx;
  background: var(--c-bg-chip);
  color: var(--c-text-2);
}
.spec-cond.new { background: rgba(48,209,88,.18); color: var(--c-green); }
.spec-cond.old { background: rgba(255,69,58,.15); color: var(--c-red); }

/* --- 价格表 --- */
.price-table { border-top: 1rpx solid var(--c-separator); }
.price-row {
  display: flex;
  justify-content: space-between;
  padding: 18rpx 0;
  border-bottom: 1rpx solid var(--c-separator);
  font-size: 28rpx;
}
.price-row:last-child { border-bottom: none; }
.price-scene { color: var(--c-text-2); }
.price-val { color: var(--c-orange); font-weight: 700; font-size: 30rpx; }

/* --- 到达攻略 --- */
.tip-line {
  display: flex;
  padding: 16rpx 0;
  line-height: 1.6;
  font-size: 28rpx;
}
.tip-icon { font-size: 36rpx; margin-right: 16rpx; flex-shrink: 0; }
.tip-text { flex: 1; color: var(--c-text); }

/* --- 热门标签 --- */
.hot-tags { display: flex; flex-wrap: wrap; gap: 12rpx; }
.hot-tag {
  padding: 8rpx 20rpx;
  background: rgba(10,132,255,.12);
  color: var(--c-blue);
  border-radius: 24rpx;
  font-size: 24rpx;
}
.hot-tag .muted { color: var(--c-text-3); }

/* --- 评论列表（卡片内） --- */
.review {
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--c-separator);
}
.review:last-child { border-bottom: none; }
.avatar {
  width: 60rpx; height: 60rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  background: var(--c-bg-chip);
}
.nickname { font-size: 28rpx; color: var(--c-text); font-weight: 500; }
.r-tags { margin-top: 12rpx; display: flex; flex-wrap: wrap; gap: 8rpx; }
.r-tag {
  font-size: 22rpx;
  color: var(--c-blue);
  padding: 2rpx 12rpx;
  background: rgba(10,132,255,.12);
  border-radius: 12rpx;
}
.content {
  margin: 14rpx 0;
  font-size: 28rpx;
  line-height: 1.65;
  color: var(--c-text);
}
.imgs { display: flex; gap: 10rpx; margin-bottom: 10rpx; flex-wrap: wrap; }
.review-img {
  width: 200rpx; height: 200rpx;
  border-radius: 12rpx;
  background: var(--c-bg-chip);
}
.empty {
  text-align: center;
  color: var(--c-text-3);
  padding: 48rpx 0;
  font-size: 26rpx;
}

/* --- 底部写点评栏 --- */
.footer-bar {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  padding: 14rpx 28rpx calc(14rpx + env(safe-area-inset-bottom));
  background: var(--c-bg);
  border-top: 1rpx solid var(--c-separator);
  z-index: 50;
}

/* --- 纠错弹窗 --- */
.mask {
  position: fixed; inset: 0;
  background: rgba(0,0,0,.52);
  z-index: 99;
  display: flex;
  align-items: flex-end;
}
.modal {
  width: 100%;
  background: var(--c-bg-elev);
  border-top-left-radius: 28rpx;
  border-top-right-radius: 28rpx;
  padding: 32rpx 28rpx calc(32rpx + env(safe-area-inset-bottom));
}
.modal-title { font-size: 34rpx; font-weight: 700; color: var(--c-text); }
.modal-sub {
  font-size: 24rpx;
  color: var(--c-text-2);
  margin-top: 8rpx;
}
.c-fields { margin: 24rpx 0; display: flex; flex-wrap: wrap; gap: 12rpx; }
.c-field {
  padding: 10rpx 26rpx;
  border: 1rpx solid var(--c-bg-chip-2);
  border-radius: 999rpx;
  font-size: 26rpx;
  color: var(--c-text-2);
  background: var(--c-bg-chip);
}
.c-field.on {
  background: var(--c-blue);
  color: #fff;
  border-color: var(--c-blue);
}
.c-input {
  width: 100%;
  min-height: 160rpx;
  padding: 20rpx;
  background: var(--c-bg-chip);
  border-radius: 16rpx;
  font-size: 28rpx;
  color: var(--c-text);
  box-sizing: border-box;
}
