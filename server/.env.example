# 深网地图 - 后端环境变量模板
# 复制此文件为 .env 并填入真实值

# 服务端口
PORT=3000

# 数据库：开发用 sqlite3，生产切 mysql
DB_CLIENT=sqlite3
DB_FILENAME=./data.db

# 上线切 MySQL 时取消下面注释
# DB_CLIENT=mysql2
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=
# DB_NAME=shenzhen_tennis_map

# 管理后台 Token（自定义一个长串）
ADMIN_TOKEN=change_me_to_a_random_long_string

# JWT 签名密钥（生产环境务必改成随机长串）
JWT_SECRET=change_me_to_a_random_secret

# 微信小程序（上线再填）
# WX_APPID=
# WX_SECRET=

# 腾讯云 COS（上线再填）
# COS_SECRET_ID=
# COS_SECRET_KEY=
# COS_BUCKET=
# COS_REGION=
